{
  "name": "betcha-server",
  "version": "0.0.1",
  "description": "",
  "license": "ISC",
  "author": "",
  "type": "commonjs",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "nodemon",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "test": "jest",
    "test:postman": "npx --yes newman run postman/Betcha-US19.postman_collection.json -e postman/Betcha-US19.postman_environment.json --working-dir postman --reporters cli,json --reporter-json-export postman/newman-report.json",
    "test:postman:us112": "npx --yes newman run postman/Betcha-US112.postman_collection.json -e postman/Betcha-US112.postman_environment.json --working-dir postman --reporters cli,json --reporter-json-export postman/newman-report-us112.json",
    "postman:jwt": "node postman/get-jwt.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.101.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "multer": "^2.1.1",
    "openai": "^6.33.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.5.2",
    "@types/pino": "^7.0.4",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.1",
    "supabase": "^2.85.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0"
  }
}
