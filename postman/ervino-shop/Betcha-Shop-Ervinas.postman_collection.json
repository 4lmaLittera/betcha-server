{
  "info": {
    "name": "Betcha — Ervino Shop testai",
    "description": "Atskira Postman kolekcija tik shop funkcionalumo testavimui (HTTP klientas ↔ Express middleware ↔ shopController ↔ Supabase). Skirta demonstracijai dėstytojui.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "Galiojantis Supabase JWT"
    },
    {
      "key": "invalidItemId",
      "value": "00000000-0000-0000-0000-000000000001",
      "type": "string",
      "description": "Neegzistuojantis item ID neigiamam pirkimo testui"
    }
  ],
  "item": [
    {
      "name": "SHOP-TC-1: Gauti aktyvias prekes + atsako laikas",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('SHOP-TC-1.1 — HTTP 200', () => pm.response.to.have.status(200));",
              "const body = pm.response.json();",
              "pm.test('SHOP-TC-1.2 — atsakymas yra masyvas', () => pm.expect(Array.isArray(body)).to.eql(true));",
              "pm.test('SHOP-TC-1.3 — kiekviena prekė turi privalomus laukus', () => {",
              "  body.forEach((item) => {",
              "    pm.expect(item).to.have.property('id').that.is.a('string');",
              "    pm.expect(item).to.have.property('name').that.is.a('string');",
              "    pm.expect(item).to.have.property('price');",
              "    pm.expect(item).to.have.property('is_active', true);",
              "  });",
              "});",
              "pm.test('SHOP-TC-1.4 — sąrašas surikiuotas pagal kainą didėjančiai', () => {",
              "  for (let i = 1; i < body.length; i++) {",
              "    pm.expect(Number(body[i].price)).to.be.at.least(Number(body[i - 1].price));",
              "  }",
              "});",
              "pm.test('SHOP-TC-1.5 — atsako laikas < 1200 ms', () => pm.expect(pm.response.responseTime).to.be.below(1200));"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/shop",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "shop"
          ]
        },
        "description": "Funkcinis + nefunkcinis testas: grąžina tik aktyvias prekes ir pakankamai greitai atsako."
      }
    },
    {
      "name": "SHOP-TC-2: Pirkimas be itemId (input validacija)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('SHOP-TC-2.1 — HTTP 400', () => pm.response.to.have.status(400));",
              "const body = pm.response.json();",
              "pm.test('SHOP-TC-2.2 — klaida dėl trūkstamų duomenų', () => pm.expect(body.error).to.eql('Trūksta duomenų pirkimui'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/shop/purchase",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "shop",
            "purchase"
          ]
        },
        "description": "Neigiamas testas: endpointas turi atmesti užklausą, kai nepateiktas itemId."
      }
    },
    {
      "name": "SHOP-TC-3: Pirkimas su neegzistuojančiu itemId",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('SHOP-TC-3.1 — HTTP 404', () => pm.response.to.have.status(404));",
              "const body = pm.response.json();",
              "pm.test('SHOP-TC-3.2 — klaida Prekė nerasta', () => pm.expect(body.error).to.eql('Prekė nerasta'));"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"itemId\": \"{{invalidItemId}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/shop/purchase",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "shop",
            "purchase"
          ]
        },
        "description": "Neigiamas testas: pirkimas negali praeiti su neegzistuojančia preke."
      }
    },
    {
      "name": "SHOP-TC-4: Be token (autorizacijos kontrolė)",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('SHOP-TC-4.1 — HTTP 401', () => pm.response.to.have.status(401));",
              "const body = pm.response.json();",
              "pm.test('SHOP-TC-4.2 — aiški auth klaida', () => pm.expect(body.error).to.match(/autorizacijos|tokenas/i));"
            ]
          }
        }
      ],
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/shop",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "shop"
          ]
        },
        "description": "Saugumo testas: endpointas privalo atmesti neautentifikuotą užklausą."
      }
    }
  ]
}